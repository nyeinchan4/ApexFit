# ============================================================
# ApexFit — Local Secrets Template
# Copy this to .secrets.env, fill in real values, then run:
#   ./scripts/apply-secrets.sh
#
# ⚠️  NEVER commit .secrets.env to git — it is gitignored.
# ============================================================

# PostgreSQL password
DB_PASSWORD=CHANGEME

# JWT signing secrets — use long random strings (64+ hex chars)
# Generate with: python3 -c "import secrets; print(secrets.token_hex(48))"
JWT_ACCESS_SECRET=CHANGEME
JWT_REFRESH_SECRET=CHANGEME
